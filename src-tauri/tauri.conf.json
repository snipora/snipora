{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "snipora",
  "version": "../package.json",
  "identifier": "com.snipora.snipora",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Snipora",
        "width": 800,
        "height": 600,
        "minWidth": 600,
        "minHeight": 400,
        "url": "main.html"
      },
      {
        "label": "popup",
        "title": "Snipora - Popup",
        "alwaysOnTop": true,
        "center": true,
        "closable": false,
        "create": false,
        "decorations": false,
        "width": 400,
        "height": 200,
        "maximizable": false,
        "minimizable": false,
        "parent": "main",
        "preventOverflow": true,
        "resizable": false,
        "shadow": false,
        "skipTaskbar": true,
        "url": "popup.html",
        "visible": false,
        "visibleOnAllWorkspaces": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "homepage": "https://github.com/snipora/snipora#README",
    "shortDescription": "Snipora is a snippet manager",
    "longDescription": "Snipora is a lightweight, local-first snippet manager for fast capture, simple organization, and quick search, keeping everyday text at your fingertips.",
    "publisher": "Snipora",
    "copyright": "© 2026 Snipora",
    "license": "GPL-3.0-or-later",
    "licenseFile": "../LICENSE",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
